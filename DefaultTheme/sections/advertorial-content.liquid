</section>

<script>
  function playVimeo(btn) {
    var wrapper = btn.closest('.video-wrapper');
    var videoId = wrapper.dataset.vimeoId;
    var iframe = document.createElement('iframe');
    iframe.src = 'https://player.vimeo.com/video/' + videoId + '?autoplay=1&muted=1&loop=1&controls=false&autopause=false';
    iframe.allow = 'autoplay; encrypted-media';
    iframe.setAttribute('allowfullscreen', '');
    wrapper.innerHTML = '';
    wrapper.appendChild(iframe);
  }
</script>

