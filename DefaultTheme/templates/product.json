fff","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_colors_solid_button_background":"#2d5f3f","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#339b43","custom_section_colors_background":"#ffffff","custom_section_gradient_background":"","image_url":"https://waggier.com/cdn/shop/files/fa1f41a2-c78b-4d27-82bc-d0c32d1c2897_copy.jpg?v=1755042848","image_alt":"Dog eating from PaceBowl"}},"custom_columns_AAnMLF":{"type":"custom-columns","blocks":{"heading_JhQmQE":{"type":"heading","settings":{"column":"col_1","visibility":"always-display","heading":"What Makes PaceBowl Different","title_highlight_color":"#339b43","heading_size":"h1","alignment":"center","mobile_alignment":"mobile-center","margin_top":20,"margin_bottom":20}},"richtext_Rhp9Uy":{"type":"richtext","settings":{"column":"col_1","visibility":"always-display","text":"<p>Premium materials and thoughtful design for years of healthy meals.</p>","text_style":"body","alignment":"center","mobile_alignment":"mobile-center","margin_top":20,"margin_bottom":20}},"icon_with_text_WTyWiG":{"type":"icon_with_text","settings":{"column":"col_2","visibility":"always-display","icon":"check_circle","filled_icon":false,"icon_size":"xxl","icon_position":"next-to-title","icon_color":"accent-1","icon_heading_size":"h3","icon_text_alignment":"left","title":"Premium 304 Stainless Steel","text":"<p>Medical-grade material that's bacteria-resistant, dishwasher safe, and built to last. No rust, no toxins, no replacement needed.</p>","margin_top":20,"margin_bottom":30}},"icon_with_text_Qeic3U":{"type":"icon_with_text","settings":{"column":"col_2","visibility":"always-display","icon":"check_circle","filled_icon":false,"icon_size":"xl","icon_position":"next-to-title","icon_color":"accent-1","icon_heading_size":"h3","icon_text_alignment":"left","title":"Perfectly Sized Honeycomb Maze","text":"<p>Hexagonal patterns slow eating by 10x without frustration. Works for all snout shapes from pugs to collies.</p>","margin_top":20,"margin_bottom":20}},"icon_with_text_LD8eBt":{"type":"icon_with_text","settings":{"column":"col_4","visibility":"always-display","icon":"check_circle","filled_icon":false,"icon_size":"xl","icon_position":"next-to-title","icon_color":"accent-1","icon_heading_size":"h3","icon_text_alignment":"left","title":"Anti-Slip Rubber Base","text":"<p>Heavy-duty rubber keeps the bowl firmly in place. No sliding, no noise, no mess, even with aggressive eaters.</p>","margin_top":20,"margin_bottom":30}},"icon_with_text_4GTwni":{"type":"icon_with_text","settings":{"column":"col_4","visibility":"always-display","icon":"check_circle","filled_icon":false,"icon_size":"xl","icon_position":"next-to-title","icon_color":"accent-1","icon_heading_size":"h3","icon_text_alignment":"left","title":"Optimal 2-4 Cup Capacity","text":"<p>Perfect for small to medium dogs. Low 1.6\" height prevents neck strain and wide 8.6\" diameter supports comfortable eating.</p>","margin_top":20,"margin_bottom":20}},"image_HgiCa3":{"type":"image","settings":{"column":"col_3","visibility":"always-display","width":100,"alignment":"center","mobile_alignment":"center","border_radius":20,"margin_top":20,"margin_bottom":20,"image_url":"https://waggier.com/cdn/shop/files/background_removed_image_IOJTg-GRR4Wreg8BR7Ho6g.png","image_alt":"PaceBowl features"}}},"block_order":["heading_JhQmQE","richtext_Rhp9Uy","icon_with_text_WTyWiG","icon_with_text_Qeic3U","icon_with_text_LD8eBt","icon_with_text_4GTwni","image_HgiCa3"],"name":"Custom columns","settings":{"display_id":false,"visibility":"always-display","color_scheme":"background-2","columns_count":4,"column_gap_desktop":40,"row_gap_desktop":40,"desktop_vertical_alignment":"center","column_gap_mobile":20,"row_gap_mobile":30,"mobile_vertical_alignment":"flex-start","col_1_desktop_width":12,"col_1_mobile_width":4,"col_1_visibility":"always-display","col_2_desktop_width":4,"col_2_mobile_width":4,"col_2_visibility":"always-display","col_3_desktop_width":4,"col_3_mobile_width":4,"col_3_visibility":"always-display","col_4_desktop_width":4,"col_4_mobile_width":4,"col_4_visibility":"always-display","col_5_desktop_width":3,"col_5_mobile_width":4,"col_5_visibility":"always-display","col_6_desktop_width":3,"col_6_mobile_width":4,"col_6_visibility":"always-display","padding_top":36,"padding_bottom":36,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#121212","custom_colors_solid_button_background":"#339b43","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#339b43"}},"testimonials_wU7ngk":{"type":"testimonials","blocks":{"column_Merc9y":{"type":"column","settings":{"title":"No More Midnight Vomit Wake-Ups!","text":"<p>My beagle Bailey used to throw up every night from eating too fast. First night with PaceBowl - nothing. It's been 3 months and not a single incident. He actually chews now. Easy to clean too. Worth every penny for peaceful nights.</p>","author":"<em><strong>Emma Rodriguez</strong></em>","image":"shopify://shop_images/4.jpg","image_url":"https://waggier.com/cdn/shop/files/4.jpg","image_alt":"Emma Rodriguez testimonial"}},"column_hqxWmJ":{"type":"column","settings":{"title":"Vet Shocked at Her Weight Loss!","text":"<p>My corgi Bella dropped 8 pounds in 2 months just from this bowl. She went from inhaling food in 20 seconds to taking 6-7 minutes. No diet change, just slower eating. My vet asked what I did differently. Buying another for my mom's dog.</p>","author":"<em><strong>Ashley Chen</strong></em>","image":"shopify://shop_images/2.jpg","image_url":"https://waggier.com/cdn/shop/files/2.jpg","image_alt":"Ashley Chen testimonial"}},"column_mCiYKk":{"type":"column","settings":{"title":"Finally - A Bowl That Actually Works!","text":"<p>Tried 3 other slow feeders and my lab figured them all out. This honeycomb design is a game changer. Takes her a full 5 minutes every meal now. No more bloat scares and no more anxiety watching her eat. Already recommended to my dog park group.</p>","author":"<em><strong>Maria Thompson</strong></em>","image":"shopify://shop_images/3.jpg","image_url":"https://waggier.com/cdn/shop/files/3.jpg","image_alt":"Maria Thompson testimonial"}}},"block_order":["column_Merc9y","column_hqxWmJ","column_mCiYKk"],"name":"Testimonials","settings":{"display_id":false,"visibility":"always-display","title":"Real Stories From Dog Moms Who Transformed Mealtime","title_highlight_color":"#339b43","heading_size":"h1","text":"","color_scheme":"background-1","image_width":"full","image_ratio":"square","column_alignment":"center","show_stars":true,"stars_color":"#ffd700","show_quotes":true,"quotes_color_scheme":"accent-2","cards_color_scheme":"bg-overlay","type":"slide","autoplay":false,"autoplay_speed":5,"arrows_color_scheme":"inverse","transparent_arrows":true,"dots_color_scheme":"inverse","desktop_full_page":false,"columns_desktop":3,"slider_desktop":false,"per_move_desktop":1,"desktop_spacing":40,"desktop_side_padding":0,"desktop_padding_calc":true,"desktop_adaptive_height":false,"desktop_dots_position":"under","desktop_arrows_position":"sides","slider_mobile":true,"enable_mobile_preview":false,"mobile_adaptive_height":false,"mobile_dots_position":"under","mobile_arrows_position":"under","padding_top":36,"padding_bottom":36,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#121212","custom_cards_colors_background":"#f3f3f3","custom_cards_gradient_background":"","custom_cards_colors_text":"#121212"}},"collapsible_content_7Ddkx4":{"type":"collapsible-content","blocks":{"collapsible_row_1":{"type":"collapsible_row","settings":{"heading":"Will this work for my flat-faced dog (pug, bulldog, etc.)?","icon":"check_box","filled_icon":false,"row_content":"<p>Yes! The honeycomb design is actually easier for flat-faced breeds than spiral mazes. The hexagonal compartments are shallow enough for pugs and bulldogs to access comfortably while still slowing them down effectively. We have hundreds of happy flat-faced customers.</p>","page":""}},"collapsible_row_2":{"type":"collapsible_row","settings":{"heading":"My dog is really smart - won't they figure out how to eat fast anyway?","icon":"check_box","filled_icon":false,"row_content":"<p>Even the smartest dogs can't physically bypass the honeycomb barriers. Unlike simple raised bumps they can eat around, our maze requires them to use their tongue to access each section individually. Studies show dogs may adapt slightly but still eat 8-10x slower than with regular bowls.</p>","page":""}},"collapsible_row_3":{"type":"collapsible_row","settings":{"heading":"What if my dog gets frustrated and stops eating?","icon":"check_box","filled_icon":false,"row_content":"<p>This rarely happens! 98% of dogs adapt within their first meal. The honeycomb design provides challenge without frustration. If your dog seems hesitant, try mixing in a small amount of wet food or treats initially. Our 90-day guarantee means you can return it if your dog truly won't use it.</p>","page":""}},"collapsible_row_4":{"type":"collapsible_row","settings":{"heading":"Is 2-4 cups enough for my medium/large dog?","icon":"check_box","filled_icon":false,"row_content":"<p>The 2-4 cup capacity is per meal, not per day. Most medium dogs eat 1.5-3 cups per meal, making this perfect. For larger dogs (over 60 lbs), you may need to split meals or consider buying two bowls. The slower eating actually helps dogs feel fuller with less food.</p>","page":""}},"collapsible_row_5":{"type":"collapsible_row","settings":{"heading":"How do I clean the maze sections?","icon":"check_box","filled_icon":false,"row_content":"<p>Super easy! The stainless steel is completely dishwasher safe - just place it on the top rack. For hand washing, the smooth steel surface rinses clean easily. No hidden crevices where food gets stuck like with plastic maze bowls. Most customers just rinse and dishwasher it daily.</p>","page":""}},"collapsible_row_6":{"type":"collapsible_row","settings":{"heading":"Will the bowl slide around while my dog eats?","icon":"check_box","filled_icon":false,"row_content":"<p>No! The heavy-duty rubber base grips your floor firmly. The bowl's weight (perfect for stability) combined with the anti-slip base means even aggressive eaters can't push it around. No more chasing bowls across the kitchen.</p>","page":""}},"collapsible_row_7":{"type":"collapsible_row","settings":{"heading":"What if my dog only eats wet food?","icon":"check_box","filled_icon":false,"row_content":"<p>Perfect for wet food too! The honeycomb design works great with pâté, chunks in gravy, or raw food. Wet food actually spreads into the compartments nicely, making dogs work to lick each section clean. Many customers use it for both wet and dry food.</p>","page":""}},"collapsible_row_8":{"type":"collapsible_row","settings":{"heading":"My dog is already a slow eater - do I need this?","icon":"check_box","filled_icon":false,"row_content":"<p>If your dog takes 5+ minutes to eat without gulping, you probably don't need this. However, many \"slow\" eaters still benefit from the mental stimulation and portion control the maze provides. Our bowl also prevents food aggression and anxiety around mealtime.</p>","page":""}},"collapsible_row_9":{"type":"collapsible_row","settings":{"heading":"Can I return it if it doesn't work for my dog?","icon":"check_box","filled_icon":false,"row_content":"<p>Absolutely! We offer a 90-day money-back guarantee. If your dog doesn't adapt or you're not completely satisfied, return it for a full refund. No questions asked, no forms to fill out. We're that confident your dog will thrive with PaceBowl.</p>","page":""}}},"block_order":["collapsible_row_1","collapsible_row_2","collapsible_row_3","collapsible_row_4","collapsible_row_5","collapsible_row_6","collapsible_row_7","collapsible_row_8","collapsible_row_9"],"name":"t:sections.collapsible_content.presets.name","settings":{"display_id":false,"visibility":"always-display","caption":"","title":"FAQs","title_highlight_color":"#339b43","heading_size":"h1","heading_alignment":"center","layout":"none","color_scheme":"background-1","container_color_scheme":"background-2","open_first_collapsible_row":false,"video_muted_autoplay":true,"image_ratio":"adapt","desktop_layout":"image_second","row_heading_size":"medium","collapse_icon":"carret","display_top_border":true,"padding_top":36,"padding_bottom":36,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#121212","custom_contaner_colors_background":"#ffffff","custom_container_gradient_background":"","custom_contaner_colors_text":"#121212"}},"image_with_text_KTAXCh":{"type":"image-with-text","blocks":{"heading_CAFqGM":{"type":"heading","settings":{"title":"<strong>Ready to Transform Your Dog's Mealtime?</strong>","title_highlight_color":"#339b43","heading_size":"h2"}},"text_e7j9HQ":{"type":"text","settings":{"text":"<p>Your dog deserves to eat without choking. You deserve peace of mind at every meal. Get your PaceBowl today and see the difference from the first meal.</p>","text_style":"body"}},"button_XgDnHV":{"type":"button","settings":{"button_label":"ADD TO CART","button_link":"shopify://products/waggier-pacebowl-2"}},"rating_stars_gebbtH":{"type":"rating_stars","settings":{"rating":4.7,"star_color":"#ffcc00","bg_stars_style":"full","bg_star_color":"#ececec","label":"4.7 | 1802 Reviews","size":16,"scroll_id":""}}},"block_order":["heading_CAFqGM","text_e7j9HQ","button_XgDnHV","rating_stars_gebbtH"],"settings":{"display_id":false,"visibility":"always-display","video_autoplay":true,"video_loop":true,"height":"medium","color_scheme":"custom","section_color_scheme":"background-1","full_desktop_width":false,"content_layout":"no-overlap","desktop_media_width":50,"layout":"image_first","desktop_content_position":"top","desktop_content_alignment":"left","mobile_full_media_width":false,"mobile_direction":"normal","mobile_image_quanlity":"2","mobile_content_alignment":"center","mobile_padding_top":0,"mobile_padding_bottom":16,"desktop_padding_top":28,"desktop_padding_bottom":28,"custom_colors_background":"#ffffff","custom_gradient_background":"","custom_colors_text":"#2e2a39","custom_colors_solid_button_background":"#2d5f3f","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#339b43","custom_section_colors_background":"#ffffff","custom_section_gradient_background":"","image_url":"https://waggier.com/cdn/shop/files/product-in-use.jpg","image_alt":"Waggier PaceBowl in use"}},"related-products":{"type":"related-products","disabled":true,"settings":{"display_id":false,"title":"You may also like","title_highlight_color":"#339b43","heading_size":"h2","products_to_show":4,"columns_desktop":4,"color_scheme":"background-1","image_ratio":"adapt","show_secondary_image":false,"show_vendor":false,"show_rating":false,"enable_quick_add":false,"columns_mobile":"2","padding_top":36,"padding_bottom":24}}},"order":["main","horizontal_ticker_nYpqJK","section_divider_xgqnJx","image_with_text_DzyLRg","image_with_text_UkqP8t","custom_columns_AAnMLF","testimonials_wU7ngk","collapsible_content_7Ddkx4","image_with_text_KTAXCh","related-products"]}